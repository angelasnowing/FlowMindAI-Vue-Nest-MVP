{
  "name": "flowmind-ai",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter @flowmind/api dev\" \"pnpm --filter @flowmind/web dev\"",
    "build": "pnpm --filter @flowmind/api build && pnpm --filter @flowmind/web build",
    "db:push": "pnpm --filter @flowmind/api db:push",
    "seed": "pnpm --filter @flowmind/api seed",
    "format": "prettier --write \"apps/**/*.{vue,ts,js,css,json,mjs}\" \"package.json\" \"pnpm-workspace.yaml\"",
    "format:check": "prettier --check \"apps/**/*.{vue,ts,js,css,json,mjs}\" \"package.json\" \"pnpm-workspace.yaml\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.9.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}
